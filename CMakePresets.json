{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 24,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "vs2022-release-physx",
      "displayName": "Visual Studio 2022 Release PhysX",
      "description": "Only supported local preset for HoCloth native builds. Requires Visual Studio/MSVC and enables the PhysX-backed runtime path.",
      "generator": "Visual Studio 17 2022",
      "architecture": {
        "value": "x64"
      },
      "toolset": "v143",
      "binaryDir": "${sourceDir}/_native/build/vs2022-release-physx",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "HOCLOTH_ENABLE_PHYSX": "ON",
        "HOCLOTH_PYTHON_EXECUTABLE": "C:/Users/Hollow/AppData/Local/Programs/Python/Python311/python.exe",
        "Python_ROOT_DIR": "C:/Users/Hollow/AppData/Local/Programs/Python/Python311",
        "HOCLOTH_PHYSX_ROOT": "${sourceDir}/_third_party/PhysX/physx",
        "HOCLOTH_PHYSX_INCLUDE_DIR": "${sourceDir}/_third_party/PhysX/physx/include",
        "HOCLOTH_PHYSX_WORK_ROOT": "${sourceDir}/_third_party/PhysX/physx",
        "HOCLOTH_PHYSX_LIBRARY_DIR": "${sourceDir}/_third_party/PhysX/physx/bin/win.x86_64.vc143.mt/release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-vs2022-release-physx",
      "displayName": "Build Visual Studio 2022 Release PhysX",
      "configurePreset": "vs2022-release-physx"
    }
  ]
}
